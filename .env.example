# AI Software Company — Environment Variables
# Copy to .env and fill in your values

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# Vector Database
PINECONE_API_KEY=pc-...
PINECONE_INDEX_NAME=ai-company-memory

# Code Sandbox
E2B_API_KEY=e2b_...

# Databases
DATABASE_URL=postgresql://aicompany:password@localhost:5432/project_state
REDIS_URL=redis://localhost:6379

# AWS (Production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Monitoring
LANGSMITH_API_KEY=ls-...
GRAFANA_PASSWORD=secure-password-here

# Notifications
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#ai-company-approvals

# Security
ENCRYPTION_KEY=...  # For secrets management
